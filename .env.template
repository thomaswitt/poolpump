# Copy to `.env` (gitignored) and fill in your values.
# Everything here is optional — defaults work for the common case.
#
# This file is read by:
#   * `docker compose up -d`  — uses the variables for service config / port maps
#   * `./poolpump.sh`         — sources it to derive the API target host
#   * `tools/reprovision.rb`  — uses it for default --module-ip / --server-hostname / SSID / PSK

# ─── tools/cloud_probe.rb (Phase 0.5 — read-only cloud baseline) ───────────
# Credentials for the still-alive Chinese cloud at fzdbiology.com.
# Used only by `tools/cloud_probe.rb` to capture ground-truth JSON snapshots
# for register reverse-engineering. Read-only — no commands sent through cloud.
# POOLPUMP_CLOUD_EMAIL=you@example.com
# POOLPUMP_CLOUD_PASSWORD='your cloud password'
# POOLPUMP_CLOUD_RTU_ID=12345678
# POOLPUMP_CLOUD_HOST=www.fzdbiology.com:8080

# ─── tools/reprovision.rb defaults ─────────────────────────────────────────
# When set, you can omit the corresponding CLI argument:
#   ruby tools/reprovision.rb show                     # uses MODULE_IP
#   ruby tools/reprovision.rb repoint                  # uses MODULE_IP + SERVER_HOSTNAME
#   ruby tools/reprovision.rb set-wifi                 # uses MODULE_IP + SSID + PSK
# POOLPUMP_MODULE_IP=192.168.0.42
# POOLPUMP_SERVER_HOSTNAME=homeserver.example.com
# POOLPUMP_SERVER_PORT=502
# POOLPUMP_WIFI_SSID=MyWifi
# POOLPUMP_WIFI_PSK='your wifi password here'

# ─── bin/poolpump-emulator (Docker / standalone) ──────────────────────────
#
# Two layers of port config:
#   * Inside the container: MODBUS_PORT / HTTP_PORT — what the Ruby process
#     binds to. Must match the AT+NETP=TCP,CLIENT,<MODBUS_PORT>,<host> you
#     set on the WiFi module via tools/reprovision.rb.
#   * On the host (compose): MODBUS_HOST_PORT / HTTP_HOST_PORT / MODBUS_HOST_BIND
#     — where on the host's network we publish the container's ports.
#
# Common configurations:
#   * Pi production (default):
#       MODBUS_PORT=502, HTTP_PORT=8090, MODBUS_HOST_PORT=502, HTTP_HOST_PORT=8090, MODBUS_HOST_BIND=0.0.0.0
#   * Mac dev with high port + ethernet-only bind:
#       MODBUS_PORT=5020, HTTP_PORT=8090, MODBUS_HOST_PORT=5020, HTTP_HOST_PORT=8090, MODBUS_HOST_BIND=192.168.x.y
#
# After setting, just `docker compose up -d` (env values come from .env).

# Container-internal ports
# MODBUS_PORT=502
# HTTP_PORT=8090
# BIND_ADDR=0.0.0.0

# Host-side published ports (compose)
# MODBUS_HOST_PORT=502
# HTTP_HOST_PORT=8090
# MODBUS_HOST_BIND=0.0.0.0

# How long an HTTP POST waits for the device echo before returning 500.
# COMMAND_DEADLINE_SEC=3.0

# Refuse writes to :HYPOTHESIZED registers (set after Phase 1 confirms map).
# POOLPUMP_STRICT=1

# ─── poolpump.sh client target ─────────────────────────────────────────────
# Where the demo CLI hits the HTTP API. If unset, falls back to deriving
# from MODBUS_HOST_BIND + HTTP_HOST_PORT above; if those are 0.0.0.0/unset
# too, falls back to localhost:8090.
# Examples:
#   POOLPUMP_HOST=localhost:8090           # on the host running the container
#   POOLPUMP_HOST=poolpump.your-domain:8090  # via DNS to a remote Pi

# ─── Auto-reboot watchdog (for the dockerised emulator) ────────────────────
# When telemetry has been silent for too long, the emulator can dispatch the
# AT+Z double-send recipe over UDP/48899 to bounce the WiFi module's TCP
# stack. Bounces only the WiFi module — NOT the controller MCU. Won't fix
# deeper Modbus-FSM wedges (those still need the panel-button arrow-key combo).
#
# REQUIRES POOLPUMP_DEVICE_IP — without it the watchdog stays disabled and
# POST /reboot returns 503.

# The Poolpump (HF-LPB130) IP. Emulator can't auto-detect it because Docker NATs.
# POOLPUMP_DEVICE_IP=192.168.0.42

# How long the snapshot must be stale before the watchdog fires (default 300s).
# Set to 0 to disable the auto-reboot watchdog while keeping POST /reboot.
# POOLPUMP_AUTO_REBOOT_AFTER_SEC=300

# Minimum gap between reboot attempts (default 300s).
# POOLPUMP_AUTO_REBOOT_COOLDOWN_SEC=300

# Max reboots in any rolling 24h window (default 6 — paranoia limit).
# POOLPUMP_AUTO_REBOOT_DAILY_LIMIT=6
